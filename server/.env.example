# Gemini API key from Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-api-key-here

# Default: free-storage File Search. Set to "cache" for an immediate rollback
# to the previous explicit context-cache implementation.
KNOWLEDGE_MODE=file-search

# Optional writable state paths for a non-root service account.
# FILE_SEARCH_DATA_FILE=/var/lib/nuvio-ai/file-search.json
# CACHE_DATA_FILE=/var/lib/nuvio-ai/cache.json

# Port for the Express server
PORT=3001

# Allowed origin for CORS (your wiki URL)
ALLOWED_ORIGIN=http://localhost:5173

# Hidden admin dashboard unlock phrase. The entire value is typed into the
# documentation search box. Keep the `nuvio-admin:` prefix and replace the
# suffix with at least 43 high-entropy base64url characters. From the `server`
# directory, generate a validated value with:
# node --input-type=module -e "import { generateAdminSecret } from './admin.js'; console.log(generateAdminSecret())"
# ADMIN_DASHBOARD_SECRET=nuvio-admin:REPLACE_WITH_A_STRONG_RANDOM_SECRET

# Trakt.tv API credentials (for Trakt Bridge Sync tool)
# Create a Trakt API app at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your-trakt-client-id-here
TRAKT_CLIENT_SECRET=your-trakt-client-secret-here

# The Movie Database (TMDB) API Key for library metadata enrichment (optional)
# Create a key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here
